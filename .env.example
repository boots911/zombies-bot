# Copy this file to ".env" and fill in your own values. Never commit ".env".

# Discord bot token (Developer Portal -> your app -> Bot)
DISCORD_TOKEN=

# Discord application (client) ID (Developer Portal -> General Information)
CLIENT_ID=

# A test server's ID — used by `node deploy-commands.js` for instant
# guild-scoped command registration. Optional; not needed for --global.
GUILD_ID=

# Hypixel API key (https://developer.hypixel.net)
HYPIXEL_API_KEY=
